# =============================================================================
# Lazo Agent — Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://lazo:lazo@localhost:5432/lazoagent
DATABASE_URL_SYNC=postgresql://lazo:lazo@localhost:5432/lazoagent
# Optional: separate read replica for analytics
# ANALYTICS_DATABASE_URL=postgresql+asyncpg://lazo:lazo@localhost:5432/lazoagent_analytics

# Pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=480
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# AI Providers
# -----------------------------------------------------------------------------
# Primary LLM (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Fallback / Router (OpenAI)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# -----------------------------------------------------------------------------
# Langfuse (Observability & Prompt Management)
# -----------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# -----------------------------------------------------------------------------
# B2Chat (Historical Knowledge Import)
# -----------------------------------------------------------------------------
B2CHAT_CLIENT_ID=your-client-id
B2CHAT_CLIENT_SECRET=your-client-secret

# -----------------------------------------------------------------------------
# Shopify
# -----------------------------------------------------------------------------
SHOPIFY_STORE_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_...
SHOPIFY_API_VERSION=2024-10
SHOPIFY_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# Twilio (WhatsApp)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_NUMBER=+14155238886

# -----------------------------------------------------------------------------
# Meta (Facebook / Instagram)
# -----------------------------------------------------------------------------
META_APP_SECRET=...
META_PAGE_ACCESS_TOKEN=...
META_VERIFY_TOKEN=lazo-verify-token
META_WHATSAPP_PHONE_ID=...
META_WHATSAPP_TOKEN=...

# -----------------------------------------------------------------------------
# Email (SMTP for inbound/outbound)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=support@lazo.com
SMTP_PASSWORD=...
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# -----------------------------------------------------------------------------
# Sentry (Error Tracking)
# -----------------------------------------------------------------------------
SENTRY_DSN=https://...

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=Lazo Agent
APP_ENV=development
LOG_LEVEL=INFO
PORT=3000

# Inbox settings
INBOX_AUTO_REPLY=true
INBOX_SLA_MINUTES=120

# Thread inactivity timeout (minutes)
THREAD_INACTIVITY_TIMEOUT=180
